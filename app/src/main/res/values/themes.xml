<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
      Main app theme. Inherits the legacy framework Material Light
      NoActionBar so we don't drag in the AppCompat / Material
      Components dependency tree (we use Material 3 via Compose, not
      XML themes). statusBarColor is transparent so the Compose
      background extends edge-to-edge.

      windowBackground is the splash color so the brief moment between
      activity launch and Compose first frame is blank-coloured, not
      white-flash. On API 31+ the platform replaces this with the
      native splash from android:windowSplashScreenBackground (see
      res/values-v31/themes.xml).

      We deliberately use this theme on the launcher activity (no
      separate Theme.App.Starting). A separate "starting" theme was
      breaking android.R.id.content on some OEM builds once we
      dropped androidx.core:core-splashscreen, producing a NPE in
      ComponentActivity.setContent at
      findViewById<ViewGroup>(android.R.id.content).getChildAt(0).
    -->
    <style name="Theme.FocusStreak" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">@bool/use_light_status</item>
        <item name="android:windowBackground">@color/splash_background</item>
    </style>

    <bool name="use_light_status">false</bool>
</resources>
