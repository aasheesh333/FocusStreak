<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Cloud backup (Auto Backup to Google Drive): include only the
         user-preferences DataStore file. -->
    <cloud-backup>
        <include domain="file" path="datastore/user_preferences.preferences_pb" />
    </cloud-backup>
    <!-- Device-to-device transfer: same policy as cloud backup. -->
    <device-transfer>
        <include domain="file" path="datastore/user_preferences.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
